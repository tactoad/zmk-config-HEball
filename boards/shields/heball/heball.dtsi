#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan_composite;
        zmk,matrix-transform = &default_transform;
        zmk,battery = &non_lipo_battery;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <53>;
        rows = <1>;
        /*
         * 左手 (col 0-27): HE1-HE27 + SW(エンコーダープッシュ)
         * 右手 (col 28-52): HE28-HE51 + SW_R(エンコーダープッシュ)
         *
         * 左手:
         *  0- 5: HE1 -HE6   (行1)
         *  6-12: HE7 -HE13  (行2)
         * 13-19: HE14-HE20  (行3)
         * 20-26: HE21-HE27  (行4)
         *    27: SW          (エンコーダープッシュボタン)
         *
         * 右手:
         * 28-33: HE28-HE33  (行1)
         * 34-40: HE34-HE40  (行2)
         * 41-47: HE41-HE47  (行3)
         * 48-51: HE48-HE51  (行4)
         *    52: SW_R        (エンコーダープッシュボタン)
         */
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)
            RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12)
            RC(0,13) RC(0,14) RC(0,15) RC(0,16) RC(0,17) RC(0,18) RC(0,19)
            RC(0,20) RC(0,21) RC(0,22) RC(0,23) RC(0,24) RC(0,25) RC(0,26)
            RC(0,27)
            RC(0,28) RC(0,29) RC(0,30) RC(0,31) RC(0,32) RC(0,33)
            RC(0,34) RC(0,35) RC(0,36) RC(0,37) RC(0,38) RC(0,39) RC(0,40)
            RC(0,41) RC(0,42) RC(0,43) RC(0,44) RC(0,45) RC(0,46) RC(0,47)
            RC(0,48) RC(0,49) RC(0,50) RC(0,51)
            RC(0,52)
        >;
    };

    /* Disable default battery monitoring */
    vbatt: vbatt {
        status = "disabled";
    };

    /* Non-LiPo (Ni-MH) battery monitoring via ADC channel 0 */
    non_lipo_battery: non_lipo_battery {
        compatible = "zmk,non-lipo-battery";
        io-channels = <&adc 0>;
    };

    /* Left EC11 Rotary Encoder: A=P1.05, B=P1.07 */
    left_encoder: encoder_left {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    /* Right EC11 Rotary Encoder: A=P1.05, B=P1.07 (same pins, different MCU) */
    right_encoder: encoder_right {
        compatible = "alps,ec11";
        a-gpios = <&gpio1 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        b-gpios = <&gpio1 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder &right_encoder>;
        triggers-per-rotation = <20>;
    };
};
